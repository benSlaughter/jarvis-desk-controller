(kicad_pcb
  (version 20231014)
  (generator "custom")
  (generator_version "8.0")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user "B.Mask")
    (39 "F.Mask" user "F.Mask")
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "Eco1.User" user "User.Eco1")
    (43 "Eco2.User" user "User.Eco2")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user "B.Fabrication")
    (49 "F.Fab" user "F.Fabrication")
  )
  (setup
    (pad_to_mask_clearance 0)
    (allow_soldermask_bridges_in_footprints no)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros no)
      (usegerberextensions no)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (dashed_line_dash_ratio 12.000000)
      (dashed_line_gap_ratio 3.000000)
      (svgprecision 4)
      (plotframeref no)
      (viasonmask no)
      (mode 1)
      (useauxorigin no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (pdf_front_fp_property_popups yes)
      (pdf_back_fp_property_popups yes)
      (dxfpolygonmode yes)
      (dxfimperialunits yes)
      (dxfusepcbnewfont yes)
      (psnegative no)
      (psa4output no)
      (plotreference yes)
      (plotvalue yes)
      (plotfptext yes)
      (plotinvisibletext no)
      (sketchpadsonfab no)
      (subtractmaskfromsilk no)
      (outputformat 1)
      (mirror no)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "gerbers/")
    )
  )

  ; ---- Nets ----
  (net 0 "")
  (net 1 "GND")
  (net 2 "VCC_5V")
  (net 3 "DTX")
  (net 4 "HTX")
  (net 5 "RX_DIV")

  ; ---- Board outline (35mm x 25mm) on Edge.Cuts ----
  (gr_line (start 0 0) (end 35 0) (stroke (width 0.1) (type solid)) (layer "Edge.Cuts") (uuid "a0000001-0001-4001-8001-000000000001"))
  (gr_line (start 35 0) (end 35 25) (stroke (width 0.1) (type solid)) (layer "Edge.Cuts") (uuid "a0000001-0001-4001-8001-000000000002"))
  (gr_line (start 35 25) (end 0 25) (stroke (width 0.1) (type solid)) (layer "Edge.Cuts") (uuid "a0000001-0001-4001-8001-000000000003"))
  (gr_line (start 0 25) (end 0 0) (stroke (width 0.1) (type solid)) (layer "Edge.Cuts") (uuid "a0000001-0001-4001-8001-000000000004"))

  ; ---- Silkscreen title ----
  (gr_text "Jarvis Desk Controller" (at 17.5 2.5) (layer "F.SilkS") (uuid "a0000001-0001-4001-8001-000000000010")
    (effects (font (size 1.2 1.2) (thickness 0.15)))
  )
  (gr_text "v1.0" (at 17.5 23) (layer "F.SilkS") (uuid "a0000001-0001-4001-8001-000000000011")
    (effects (font (size 1 1) (thickness 0.12)))
  )

  ; ---- Mounting Holes ----
  (footprint "MountingHole:MountingHole_2.2mm_M2"
    (layer "F.Cu")
    (uuid "b0000001-0001-4001-8001-000000000001")
    (at 3 3)
    (property "Reference" "H1" (at 0 -2.5 0) (layer "F.SilkS") (uuid "b0000001-0001-4001-8001-100000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole_M2" (at 0 2.5 0) (layer "F.Fab") (uuid "b0000001-0001-4001-8001-100000000002") (effects (font (size 1 1) (thickness 0.15))))
    (property "Footprint" "MountingHole:MountingHole_2.2mm_M2" (at 0 0 0) (layer "F.Fab") (uuid "b0000001-0001-4001-8001-100000000003") (effects (font (size 1.27 1.27)) hide))
    (pad "" np_thru_hole circle (at 0 0) (size 2.2 2.2) (drill 2.2) (layers "*.Cu" "*.Mask") (uuid "b0000001-0001-4001-8001-200000000001"))
  )
  (footprint "MountingHole:MountingHole_2.2mm_M2"
    (layer "F.Cu")
    (uuid "b0000001-0001-4001-8001-000000000002")
    (at 32 22)
    (property "Reference" "H2" (at 0 -2.5 0) (layer "F.SilkS") (uuid "b0000001-0001-4001-8001-100000000004") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole_M2" (at 0 2.5 0) (layer "F.Fab") (uuid "b0000001-0001-4001-8001-100000000005") (effects (font (size 1 1) (thickness 0.15))))
    (property "Footprint" "MountingHole:MountingHole_2.2mm_M2" (at 0 0 0) (layer "F.Fab") (uuid "b0000001-0001-4001-8001-100000000006") (effects (font (size 1.27 1.27)) hide))
    (pad "" np_thru_hole circle (at 0 0) (size 2.2 2.2) (drill 2.2) (layers "*.Cu" "*.Mask") (uuid "b0000001-0001-4001-8001-200000000002"))
  )

  ; ---- J1: RJ12 connector (left edge, centered vertically) ----
  (footprint "Connector_RJ:RJ12_Amphenol_54601"
    (layer "F.Cu")
    (uuid "c0000001-0001-4001-8001-000000000001")
    (at 4 12.5)
    (property "Reference" "J1" (at 0 -6 0) (layer "F.SilkS") (uuid "c0000001-0001-4001-8001-100000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "RJ12_6P6C" (at 0 6 0) (layer "F.Fab") (uuid "c0000001-0001-4001-8001-100000000002") (effects (font (size 1 1) (thickness 0.15))))
    (property "Footprint" "Connector_RJ:RJ12_Amphenol_54601" (at 0 0 0) (layer "F.Fab") (uuid "c0000001-0001-4001-8001-100000000003") (effects (font (size 1.27 1.27)) hide))
    (pad "1" thru_hole circle (at -3.175 0) (size 1.6 1.6) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 "") (uuid "c0000001-0001-4001-8001-200000000001"))
    (pad "2" thru_hole circle (at -1.905 0) (size 1.6 1.6) (drill 1.0) (layers "*.Cu" "*.Mask") (net 1 "GND") (uuid "c0000001-0001-4001-8001-200000000002"))
    (pad "3" thru_hole circle (at -0.635 0) (size 1.6 1.6) (drill 1.0) (layers "*.Cu" "*.Mask") (net 3 "DTX") (uuid "c0000001-0001-4001-8001-200000000003"))
    (pad "4" thru_hole circle (at 0.635 0) (size 1.6 1.6) (drill 1.0) (layers "*.Cu" "*.Mask") (net 2 "VCC_5V") (uuid "c0000001-0001-4001-8001-200000000004"))
    (pad "5" thru_hole circle (at 1.905 0) (size 1.6 1.6) (drill 1.0) (layers "*.Cu" "*.Mask") (net 4 "HTX") (uuid "c0000001-0001-4001-8001-200000000005"))
    (pad "6" thru_hole circle (at 3.175 0) (size 1.6 1.6) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 "") (uuid "c0000001-0001-4001-8001-200000000006"))
  )

  ; ---- R1: 1kΩ SMD 0805 (between J1 and U1) ----
  (footprint "Resistor_SMD:R_0805_2012Metric"
    (layer "F.Cu")
    (uuid "d0000001-0001-4001-8001-000000000001")
    (at 13 10)
    (property "Reference" "R1" (at 0 -1.5 0) (layer "F.SilkS") (uuid "d0000001-0001-4001-8001-100000000001") (effects (font (size 0.8 0.8) (thickness 0.12))))
    (property "Value" "1k" (at 0 1.5 0) (layer "F.Fab") (uuid "d0000001-0001-4001-8001-100000000002") (effects (font (size 0.8 0.8) (thickness 0.12))))
    (property "Footprint" "Resistor_SMD:R_0805_2012Metric" (at 0 0 0) (layer "F.Fab") (uuid "d0000001-0001-4001-8001-100000000003") (effects (font (size 1.27 1.27)) hide))
    (pad "1" smd roundrect (at -1 0) (size 1.0 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25) (net 3 "DTX") (uuid "d0000001-0001-4001-8001-200000000001"))
    (pad "2" smd roundrect (at 1 0) (size 1.0 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25) (net 5 "RX_DIV") (uuid "d0000001-0001-4001-8001-200000000002"))
  )

  ; ---- R2: 2kΩ SMD 0805 (between J1 and U1, below R1) ----
  (footprint "Resistor_SMD:R_0805_2012Metric"
    (layer "F.Cu")
    (uuid "d0000001-0001-4001-8001-000000000002")
    (at 13 15)
    (property "Reference" "R2" (at 0 -1.5 0) (layer "F.SilkS") (uuid "d0000001-0001-4001-8001-100000000004") (effects (font (size 0.8 0.8) (thickness 0.12))))
    (property "Value" "2k" (at 0 1.5 0) (layer "F.Fab") (uuid "d0000001-0001-4001-8001-100000000005") (effects (font (size 0.8 0.8) (thickness 0.12))))
    (property "Footprint" "Resistor_SMD:R_0805_2012Metric" (at 0 0 0) (layer "F.Fab") (uuid "d0000001-0001-4001-8001-100000000006") (effects (font (size 1.27 1.27)) hide))
    (pad "1" smd roundrect (at -1 0) (size 1.0 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25) (net 5 "RX_DIV") (uuid "d0000001-0001-4001-8001-200000000003"))
    (pad "2" smd roundrect (at 1 0) (size 1.0 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25) (net 1 "GND") (uuid "d0000001-0001-4001-8001-200000000004"))
  )

  ; ---- U1: Beetle ESP32-C6 as 2x7 pin header (centered on board) ----
  ; Pin mapping: 1=VIN, 3=GND_in, 7=GPIO17(RX), 9=GPIO18(TX), 13=GND
  (footprint "Connector_PinHeader_2.54mm:PinHeader_2x07_P2.54mm_Vertical"
    (layer "F.Cu")
    (uuid "e0000001-0001-4001-8001-000000000001")
    (at 25 12.5)
    (property "Reference" "U1" (at 1.27 -10 0) (layer "F.SilkS") (uuid "e0000001-0001-4001-8001-100000000001") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "Beetle_ESP32-C6" (at 1.27 10 0) (layer "F.Fab") (uuid "e0000001-0001-4001-8001-100000000002") (effects (font (size 1 1) (thickness 0.15))))
    (property "Footprint" "Connector_PinHeader_2.54mm:PinHeader_2x07_P2.54mm_Vertical" (at 0 0 0) (layer "F.Fab") (uuid "e0000001-0001-4001-8001-100000000003") (effects (font (size 1.27 1.27)) hide))
    (pad "1" thru_hole rect (at 0 0) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 2 "VCC_5V") (uuid "e0000001-0001-4001-8001-200000000001"))
    (pad "2" thru_hole oval (at 2.54 0) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 "") (uuid "e0000001-0001-4001-8001-200000000002"))
    (pad "3" thru_hole oval (at 0 2.54) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 "") (uuid "e0000001-0001-4001-8001-200000000003"))
    (pad "4" thru_hole oval (at 2.54 2.54) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 "") (uuid "e0000001-0001-4001-8001-200000000004"))
    (pad "5" thru_hole oval (at 0 5.08) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 "") (uuid "e0000001-0001-4001-8001-200000000005"))
    (pad "6" thru_hole oval (at 2.54 5.08) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 "") (uuid "e0000001-0001-4001-8001-200000000006"))
    (pad "7" thru_hole oval (at 0 7.62) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 5 "RX_DIV") (uuid "e0000001-0001-4001-8001-200000000007"))
    (pad "8" thru_hole oval (at 2.54 7.62) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 "") (uuid "e0000001-0001-4001-8001-200000000008"))
    (pad "9" thru_hole oval (at 0 10.16) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 4 "HTX") (uuid "e0000001-0001-4001-8001-200000000009"))
    (pad "10" thru_hole oval (at 2.54 10.16) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 "") (uuid "e0000001-0001-4001-8001-200000000010"))
    (pad "11" thru_hole oval (at 0 12.7) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 "") (uuid "e0000001-0001-4001-8001-200000000011"))
    (pad "12" thru_hole oval (at 2.54 12.7) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 "") (uuid "e0000001-0001-4001-8001-200000000012"))
    (pad "13" thru_hole oval (at 0 15.24) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 1 "GND") (uuid "e0000001-0001-4001-8001-200000000013"))
    (pad "14" thru_hole oval (at 2.54 15.24) (size 1.7 1.7) (drill 1.0) (layers "*.Cu" "*.Mask") (net 0 "") (uuid "e0000001-0001-4001-8001-200000000014"))
  )

  ; ---- Copper Traces (F.Cu) ----

  ; Power: VCC_5V - J1 pin 4 to U1 pin 1 (0.5mm width)
  (segment (start 4.635 12.5) (end 4.635 6) (width 0.5) (layer "F.Cu") (net 2) (uuid "f0000001-0001-4001-8001-000000000001"))
  (segment (start 4.635 6) (end 25 6) (width 0.5) (layer "F.Cu") (net 2) (uuid "f0000001-0001-4001-8001-000000000002"))
  (segment (start 25 6) (end 25 12.5) (width 0.5) (layer "F.Cu") (net 2) (uuid "f0000001-0001-4001-8001-000000000003"))

  ; Power: GND - J1 pin 2 to R2 pad 2, to U1 pin 13 (0.5mm width)
  (segment (start 2.095 12.5) (end 2.095 19) (width 0.5) (layer "F.Cu") (net 1) (uuid "f0000001-0001-4001-8001-000000000004"))
  (segment (start 2.095 19) (end 14 19) (width 0.5) (layer "F.Cu") (net 1) (uuid "f0000001-0001-4001-8001-000000000005"))
  (segment (start 14 19) (end 14 15) (width 0.5) (layer "F.Cu") (net 1) (uuid "f0000001-0001-4001-8001-000000000006"))
  (segment (start 14 19) (end 25 19) (width 0.5) (layer "F.Cu") (net 1) (uuid "f0000001-0001-4001-8001-000000000007"))
  (segment (start 25 19) (end 25 27.74) (width 0.5) (layer "F.Cu") (net 1) (uuid "f0000001-0001-4001-8001-000000000008"))

  ; Signal: DTX - J1 pin 3 to R1 pad 1 (0.25mm width)
  (segment (start 3.365 12.5) (end 3.365 10) (width 0.25) (layer "F.Cu") (net 3) (uuid "f0000001-0001-4001-8001-000000000009"))
  (segment (start 3.365 10) (end 12 10) (width 0.25) (layer "F.Cu") (net 3) (uuid "f0000001-0001-4001-8001-000000000010"))

  ; Signal: RX_DIV - R1 pad 2 to R2 pad 1 junction, then to U1 pin 7/GPIO17 (0.25mm width)
  (segment (start 14 10) (end 16 10) (width 0.25) (layer "F.Cu") (net 5) (uuid "f0000001-0001-4001-8001-000000000011"))
  (segment (start 16 10) (end 16 15) (width 0.25) (layer "F.Cu") (net 5) (uuid "f0000001-0001-4001-8001-000000000012"))
  (segment (start 16 15) (end 12 15) (width 0.25) (layer "F.Cu") (net 5) (uuid "f0000001-0001-4001-8001-000000000013"))
  (segment (start 16 10) (end 16 8) (width 0.25) (layer "F.Cu") (net 5) (uuid "f0000001-0001-4001-8001-000000000014"))
  (segment (start 16 8) (end 25 8) (width 0.25) (layer "F.Cu") (net 5) (uuid "f0000001-0001-4001-8001-000000000015"))
  (segment (start 25 8) (end 25 20.12) (width 0.25) (layer "F.Cu") (net 5) (uuid "f0000001-0001-4001-8001-000000000016"))

  ; Signal: HTX - J1 pin 5 to U1 pin 9/GPIO18 (0.25mm width)
  (segment (start 5.905 12.5) (end 5.905 22) (width 0.25) (layer "F.Cu") (net 4) (uuid "f0000001-0001-4001-8001-000000000017"))
  (segment (start 5.905 22) (end 20 22) (width 0.25) (layer "F.Cu") (net 4) (uuid "f0000001-0001-4001-8001-000000000018"))
  (segment (start 20 22) (end 20 22.66) (width 0.25) (layer "F.Cu") (net 4) (uuid "f0000001-0001-4001-8001-000000000019"))
  (segment (start 20 22.66) (end 25 22.66) (width 0.25) (layer "F.Cu") (net 4) (uuid "f0000001-0001-4001-8001-000000000020"))

  ; ---- Ground Pour on B.Cu ----
  (zone
    (net 1)
    (net_name "GND")
    (layer "B.Cu")
    (uuid "f0000001-0001-4001-8001-000000000099")
    (hatch edge 0.5)
    (connect_pads (clearance 0.3))
    (min_thickness 0.25)
    (filled_areas_thickness no)
    (fill yes (thermal_gap 0.5) (thermal_bridge_width 0.5))
    (polygon
      (pts
        (xy 0 0) (xy 35 0) (xy 35 25) (xy 0 25)
      )
    )
  )
)
